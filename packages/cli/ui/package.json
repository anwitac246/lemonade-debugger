{
	"name": "ui",
	"version": "0.0.0",
	"license": "MIT",
	"bin": "dist/cli.js",
	"type": "module",
	"engines": {
		"node": ">=16"
	},
	"scripts": {
		"build": "babel --out-dir=dist source",
		"dev": "npm run build && node dist/cli.js",
		"test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"figlet": "^1.10.0",
		"gradient-string": "^3.0.0",
		"ink": "^4.1.0",
		"meow": "^11.0.0",
		"node-pty": "^1.1.0",
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@babel/cli": "^7.21.0",
		"@babel/preset-env": "^7.29.0",
		"@babel/preset-react": "^7.28.5",
		"@vdemedes/prettier-config": "^2.0.1",
		"babel-jest": "^30.2.0",
		"chalk": "^5.2.0",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"import-jsx": "^5.0.0",
		"ink-testing-library": "^3.0.0",
		"jest": "^30.2.0",
		"prettier": "^2.8.7",
		"xo": "^0.53.1"
	},
	"ava": {
		"environmentVariables": {
			"NODE_NO_WARNINGS": "1"
		},
		"nodeArguments": [
			"--loader=import-jsx"
		]
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off",
			"unicorn/expiring-todo-comments": "off"
		},
		"envs": [
			"jest"
		],
		"overrides": [
			{
				"files": [
					"test.js"
				],
				"rules": {
					"unicorn/prefer-module": "off"
				}
			}
		]
	},
	"prettier": "@vdemedes/prettier-config",
	"babel": {
		"presets": [
			"@babel/preset-react"
		]
	}
}
